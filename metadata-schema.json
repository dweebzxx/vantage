{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pass Metadata",
  "description": "Machine-readable record for one AI assistant pass",
  "type": "object",
  "required": [
    "pass_id",
    "pass_name",
    "date",
    "model",
    "status",
    "workflow_guide_version",
    "agent_md_present",
    "agent_md_authorized",
    "agent_md_authority",
    "agent_md_maintenance_score",
    "schema_present",
    "gitignore_correct",
    "prompt_saved",
    "launcher_saved",
    "build_result",
    "files_read",
    "files_created",
    "files_modified",
    "pre_existing_dirty_files",
    "validation",
    "version_bumped",
    "committed",
    "pushed",
    "manual_verification_required",
    "report_path"
  ],
  "properties": {
    "pass_id": {
      "type": "string",
      "description": "Full PASS_ID stem e.g. 26-05-09_P38_queue-prefix-selection. Never abbreviated."
    },
    "pass_name": {
      "type": "string",
      "description": "Human-readable pass name."
    },
    "date": {
      "type": "string",
      "description": "ISO date e.g. 2026-06-29"
    },
    "model": {
      "type": "string",
      "description": "Model string used."
    },
    "status": {
      "type": "string",
      "enum": [
        "BUILD_SUCCEEDED",
        "BUILD_FAILED",
        "DOCUMENTATION_ONLY",
        "WORKFLOW_ONLY",
        "PARTIAL",
        "BLOCKED"
      ]
    },
    "workflow_guide_version": {
      "type": "string"
    },
    "agent_md_present": {
      "type": "boolean"
    },
    "agent_md_authorized": {
      "type": "boolean"
    },
    "agent_md_authority": {
      "type": "string",
      "enum": [
        "created_by_p01_bootstrap",
        "accepted_by_p01_adoption_bootstrap",
        "accepted_by_remediation_pass",
        "not_present",
        "unknown"
      ]
    },
    "agent_md_maintenance_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "schema_present": {
      "type": "boolean"
    },
    "gitignore_correct": {
      "type": "boolean"
    },
    "prompt_saved": {
      "type": "boolean"
    },
    "launcher_saved": {
      "type": "boolean"
    },
    "build_result": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "outcome",
            "artifact"
          ],
          "properties": {
            "outcome": {
              "type": "string",
              "enum": [
                "SUCCEEDED",
                "FAILED",
                "NOT_RUN"
              ]
            },
            "app_version": {
              "type": "string"
            },
            "bundle_version": {
              "type": "string"
            },
            "artifact": {
              "type": "string"
            },
            "configuration": {
              "type": "string",
              "enum": [
                "Release",
                "Debug"
              ]
            },
            "signing_status": {
              "type": "string"
            },
            "notarization_status": {
              "type": "string"
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "files_read": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files_created": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files_modified": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pre_existing_dirty_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object"
    },
    "version_bumped": {
      "type": "boolean"
    },
    "committed": {
      "type": "boolean"
    },
    "pushed": {
      "type": "boolean"
    },
    "manual_verification_required": {
      "type": "boolean"
    },
    "report_path": {
      "type": "string"
    },
    "behavior_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "summary",
          "files_affected"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "files_affected": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "duration_seconds": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "total_tokens_used": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
